import java.io.*;
import java.util.*;

public class tryHeapsort {
    
    // Heap class to handle heap operations
    static class Heap {
        private String[] heapArray;
        private int size;
        
        // Constructor
        public Heap(int capacity) {
            heapArray = new String[capacity];
            size = 0;
        }
        
        // Build the heap bottom-up (O(n))
        public void buildBottomUp(String[] words, int n) {
            this.heapArray = words;
            this.size = n;
            
            // Start from the last parent node and heapify downwards
            for (int i = (n/2 - 1); i >= 0; i--) {
                heapifyDown(i, n);
            }
        }
        
        // Build the heap top-down (O(n log n)) by repeated inserts
        public void buildTopDown(String[] words, int n) {
            this.heapArray = new String[n];
            this.size = 0;
            
            // Insert each word one by one
            for (int i = 0; i < n; i++) {
                insert(words[i]);
            }

            // Copy back to original array
            for (int i = 0; i < n; i++) {
                words[i] = heapArray[i];
            }
        }
        
        // Insert element into the heap (for top-down)
        public void insert(String word) {
            if (size >= heapArray.length) return;
            
            heapArray[size] = word;
            int current = size;
            size++;
            
            // Heapify up (bubble up)
            while (current > 0) {
                int parent = (current - 1) / 2;
                if (heapArray[current].compareTo(heapArray[parent]) > 0) {
                    swap(current, parent);
                    current = parent;
                } else {
                    break;
                }
            }
        }
        // Heapify down (for bottom-up build and sorting)
        private void heapifyDown(int index, int heapSize) {
            int largest = index;
            int left = 2 * index + 1;
            int right = 2 * index + 2;
            
            if (left < heapSize && heapArray[left].compareTo(heapArray[largest]) > 0) {
                largest = left;
            }
            
            if (right < heapSize && heapArray[right].compareTo(heapArray[largest]) > 0) {
                largest = right;
            }
            
            if (largest != index) {
                swap(index, largest);
                heapifyDown(largest, heapSize);
            }
        }
        
        // Extract max (for sorting)
        private String extractMax(int heapSize) {
            if (heapSize <= 0) return null;
            
            String max = heapArray[0];
            heapArray[0] = heapArray[heapSize - 1];
            heapifyDown(0, heapSize - 1);
            return max;
        }
        
        // Sort the heap (common for both construction methods)
        public String[] heapSort() {
            String[] sorted = new String[size];
            
            // Extract elements in descending order and place at the end
            for (int i = size - 1; i >= 0; i--) {
                swap(0, i);
                heapifyDown(0, i);
            }
            
            // Array is now in ascending order
            return heapArray;
        }
        
        // Swap helper
        private void swap(int i, int j) {
            String temp = heapArray[i];
            heapArray[i] = heapArray[j];
            heapArray[j] = temp;
        }
    }
    
    // Timing class (reused from previous practicals)
    static class Timer {
        private long startTime;
        private long endTime;
        
        public void start() {
            startTime = System.nanoTime();
        }
        
        public void stop() {
            endTime = System.nanoTime();
        }
        
        public double getTimeMilliseconds() {
            return (endTime - startTime) / 1_000_000.0;
        }
        
        public void reset() {
            startTime = 0;
            endTime = 0;
        }
    }
    
    // Main method
    public static void main(String[] args) {
        try {
            // Load words from file
            String[] words = loadWords("ulysses_clean.txt");
            System.out.println("Loaded " + words.length + " words from Ulysses");

            // Test with small array first
            System.out.println("\n=== TESTING WITH SMALL ARRAY (20 WORDS) ===");
            testWithSmallArray(words);
            
            // Test with full dataset
            System.out.println("\n=== TESTING WITH FULL DATASET ===");
            testWithFullDataset(words);
            
        } catch (IOException e) {
            System.out.println("Error loading file: " + e.getMessage());
        }
    }
    
    // Load words from file
    private static String[] loadWords(String filename) throws IOException {
        ArrayList<String> wordList = new ArrayList<>();
        BufferedReader reader = new BufferedReader(new FileReader(filename));
        String line;
        
        while ((line = reader.readLine()) != null) {
            String[] words = line.trim().split("\\s+");
            for (String word : words) {
                if (!word.isEmpty()) {
                    wordList.add(word.toLowerCase());
                }
            }
        }
        reader.close();
        
        return wordList.toArray(new String[0]);
    }
    
    // Test with small array
    private static void testWithSmallArray(String[] allWords) {
        // Take first 20 words
        String[] testWords = Arrays.copyOfRange(allWords, 0, 20);
        
        System.out.println("Original words (first 10):");
        for (int i = 0; i < 10; i++) {
            System.out.print(testWords[i] + " ");
        }
        System.out.println("\n");
        
        // Test bottom-up
        System.out.println("Bottom-up construction:");
        String[] bottomUpWords = testWords.clone();
        Heap heap1 = new Heap(bottomUpWords.length);
        heap1.buildBottomUp(bottomUpWords, bottomUpWords.length);
        String[] sorted1 = heap1.heapSort();
        System.out.println("Sorted (first 10):");
        for (int i = 0; i < 10; i++) {
            System.out.print(sorted1[i] + " ");
        }
        System.out.println("\n");
        
        // Test top-down
        System.out.println("Top-down construction:");
        String[] topDownWords = testWords.clone();
        Heap heap2 = new Heap(topDownWords.length);
        heap2.buildTopDown(topDownWords, topDownWords.length);
        String[] sorted2 = heap2.heapSort();
        System.out.println("Sorted (first 10):");
        for (int i = 0; i < 10; i++) {
            System.out.print(sorted2[i] + " ");
        }
        System.out.println("\n");
        
        // Verify both sorts produce same result
        System.out.println("Sorts match: " + Arrays.equals(sorted1, sorted2));
    }
    
            
        
